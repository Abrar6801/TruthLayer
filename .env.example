# Copy this file to .env and fill in real values. .env is gitignored — keep it that way.

# Anthropic API key for verdict generation (platform.claude.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Supabase service_role key — SERVER-SIDE ONLY. Bypasses Row Level Security.
# Must never appear in any client-facing code, log, or error message.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Tavily web search API key (app.tavily.com)
TAVILY_API_KEY=tvly-your-key-here
