# Copy this file to .env and fill in real values. .env is gitignored — keep it that way.

# Anthropic API key for verdict generation (platform.claude.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Tavily web search API key (app.tavily.com)
TAVILY_API_KEY=tvly-your-key-here

# OpenAI API key, used ONLY for hosted embeddings (text-embedding-3-small,
# truncated to 384 dims to match the DB schema — see embedding.py). Not used
# for chat/completions. platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Postgres connection string (SERVER-SIDE SECRET — never expose to the frontend).
# Local dev with docker compose:  postgresql://truthlayer:truthlayer@localhost:5433/truthlayer
# Production (Supabase): dashboard → Connect → Session pooler URI, e.g.
#   postgresql://postgres.<ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://truthlayer:truthlayer@localhost:5433/truthlayer

# --- API service (Phase 2) ---
# TruthLayer's OWN service auth key — the Next.js server presents this to
# FastAPI in the X-API-Key header. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TRUTHLAYER_API_KEY=generate-a-random-key-here
# Comma-separated CORS allowlist (the frontend origin only)
ALLOWED_ORIGINS=http://localhost:3000
# slowapi rate limit for /verify
VERIFY_RATE_LIMIT=10/minute

# --- LangSmith tracing (Phase 3, optional) ---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2-your-key-here
# LANGSMITH_PROJECT=truthlayer
