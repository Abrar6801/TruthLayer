# Copy to .env.local (gitignored by create-next-app's .gitignore).
#
# BOTH of these are server-only (no NEXT_PUBLIC_ prefix — they must never be
# inlined into the browser bundle). The route handler at /api/verify reads
# them; the browser never sees the backend URL or key.

# FastAPI backend base URL (local Docker: http://localhost:8000)
TRUTHLAYER_API_URL=http://localhost:8000

# Must match TRUTHLAYER_API_KEY in the backend's .env
TRUTHLAYER_API_KEY=paste-the-same-key-as-the-backend
